# Environment variables (optional)
# Copy this file to .env if you prefer environment variables over config files

# Browser settings
HEADLESS=false
DELAY_BETWEEN_ACCOUNTS=5000

# Target service configuration (advanced)
# Customize these if you're using a different OAuth service
# TARGET_URL=https://your-service.com/signin
# TARGET_DOMAIN=**/your-service.com/**

# Router API endpoints (advanced)
# Customize these if your router uses different paths
# ROUTER_OAUTH_ENDPOINT=/api/oauth/service
# ROUTER_IMPORT_ENDPOINT=/api/oauth/service/import

# Token router configuration (alternative to 9router.json)
# ROUTER_ENDPOINT=http://localhost:20128
# ROUTER_PASSWORD=your_password

# GSuite configuration (alternative to gsuite.txt + password-gsuite.txt)
# GSUITE_PASSWORD=your_shared_password
